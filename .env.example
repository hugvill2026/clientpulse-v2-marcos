# CLIENTPULSE V2 - ENVIROMENT VARIABLES
# Rename to .env to use in development

# FIREBASE CONFIG (Required for Auth & Database)
# Find these in Project Settings > General > SDK Setup
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=clientpulse001.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=clientpulse001
VITE_FIREBASE_STORAGE_BUCKET=clientpulse001.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id_here

# EMAILJS CONFIG (Optional for activity reports)
VITE_EMAILJS_SERVICE_ID=service_xxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxx

# WHATSAPP REMINDERS (CallMeBot)
# Message 'I allow callmebot to send me messages' to +34 644 59 32 07
VITE_CALLMEBOT_PHONE=+593...
VITE_CALLMEBOT_API_KEY=your_callmebot_apikey

# GOOGLE APPS SCRIPT (Optional for Sheets Integration)
VITE_GAS_WEBHOOK_URL=your_google_scripts_url
